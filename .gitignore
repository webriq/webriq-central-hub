# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets
.env
.env.local
.env.*.local
# env.example IS committed (no real values)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vexp/index.db-shm
.vexp/index.db-wal
.vexpignore
.vexp/index.db

_backup (DO NOT READ)/

_design/
_design_(OLD)
appstore-images/

supabase/.temp/

.claude/worktrees/