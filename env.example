# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Service role key — server-only, never expose to the client
SUPABASE_SECRET_KEY=your-secret-key

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Anthropic — default provider for all layers
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — optional, switch any layer to OpenAI via llm_config.provider='openai'
# Found in: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to your production domain (e.g. https://hub.webriq.com) in .env.local.
# Used in invite emails as the redirectTo base URL. Must also be added to
# Supabase Dashboard → Auth → URL Configuration → Allowed Redirect URLs.
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ─── Zoho ─────────────────────────────────────────────────────────────────────
# OAuth 2.0 credentials for Zoho Projects, Desk, and Cliq (Sprint 2+)
# These same credentials are entered in Supabase Dashboard (Auth → Providers → Custom → zoho)
# to enable "Sign in with Zoho". Supabase callback URI: https://[project-ref].supabase.co/auth/v1/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Zoho Projects portal ID (numeric) — used in API calls
# Found in: Zoho Projects → Settings → Portal Details
ZOHO_PORTAL_ID=
# Zoho Projects portal name (slug) — used for web URL construction (NEXT_PUBLIC = safe for client)
# Find it in your Zoho Projects URL: https://projects.zoho.com/portal/{name}/
NEXT_PUBLIC_ZOHO_PORTAL_NAME=
# Base URL for your Zoho org (e.g. https://projectsapi.zoho.com)
ZOHO_API_BASE_URL=
# Zoho Desk organization ID (numeric) — sent as the required "orgId" header on every Desk API call.
# Found in: Zoho Desk → Setup → Developer Space → API. NOTE: your API client's OAuth scope must
# also include Desk.accounts.READ (in addition to Desk.contacts.READ) for account/company matching
# to work (task 117) — adding a scope in the Zoho console requires regenerating ZOHO_REFRESH_TOKEN,
# since existing refresh tokens are scope-locked at creation.
ZOHO_DESK_ORG_ID=

# ─── Sanity (Sprint 5+) ───────────────────────────────────────────────────────
# Sanity API token (editor access) — project ID is stored per customer_products row
SANITY_API_TOKEN=
# Robot account (automation@webriq.com) — Editor on all Sanity client projects
# Setup: create account → add to projects → generate token from sanity.io/manage
SANITY_GLOBAL_TOKEN=
# Sanity Presentation Tool preview secret (2hr expiry for draft preview URLs)
SANITY_PREVIEW_SECRET=

# ─── GitHub (Sprint 5+) ───────────────────────────────────────────────────────
# Fine-grained PAT with repo read/write for PR creation
GITHUB_TOKEN=

# ─── Webhook security (Sprint 2+) ────────────────────────────────────────────
# HMAC key from Zoho Projects → Settings → Automation → Webhooks → Security Settings.
# Zoho signs the raw POST body with HMAC-SHA256 and sends it in X-ZP-WEBHOOK-SIGNATURE (base64).
ZOHO_WEBHOOK_SECRET=

# ─── Cron job security (Sprint 3+) ────────────────────────────────────────────
# Shared secret between pg_cron (Supabase) and every cron-triggered route: /api/digest,
# /api/kb/lint, /api/admin/zoho-sync/tasklists, /api/programme/reminders,
# /api/onboarding/scheduled-autostart. Renamed from DIGEST_SECRET — that name stopped being
# accurate once routes beyond the digest started sharing it (migration 078).
# Cron jobs read this via a Supabase Vault secret named `cron_secret_key` (see migrations
# 077/078), not directly from this env var — set the same value in both places.
CRONJOB_SECRET_KEY=

# ─── QStash (chat follow-up to task 157) ──────────────────────────────────────
# One-shot, exact-time scheduled onboarding start — fires at the scheduled instant instead of
# waiting for the next cron poll tick. Copy all three from the Upstash console (console.upstash.com/qstash).
# The cron poll (onboarding-scheduled-autostart) stays as a fallback in case a QStash delivery fails.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Required if your QStash token/user was created under a specific region (e.g. us-east-1) — the
# global endpoint's auto-routing does not reliably resolve to your account's actual home region,
# and calling it from a different region returns "user not found in this region". Set this to
# match wherever you created your token in the Upstash console, e.g.:
# QSTASH_URL=https://qstash-us-east-1.upstash.io
QSTASH_URL=

# ─── Reply route security (Sprint 5+) ────────────────────────────────────────
REPLY_SECRET=                    # Shared secret for POST /api/reply (internal route); generate with: openssl rand -hex 32

# ─── Zoho Cliq channels (Sprint 3+) ──────────────────────────────────────────
# PM digest and general notifications (set in Sprint 2)
# ZOHO_CLIQ_WEBHOOK_URL and ZOHO_CLIQ_WEBHOOK_TOKEN defined above under Zoho section
# Separate channel for dev digest notifications
ZOHO_CLIQ_DEV_WEBHOOK_URL=

# ─── Push Notifications ──────────────────────────────────────────────────────
# Generate VAPID keys: node -e "const webpush = require('web-push'); console.log(webpush.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=                    # server-side signing key
VAPID_PRIVATE_KEY=                   # server-side — never expose to client
NEXT_PUBLIC_VAPID_PUBLIC_KEY=        # same value as VAPID_PUBLIC_KEY — exposed to browser for PushManager.subscribe()

# ─── Email / SMTP (task 085+) ─────────────────────────────────────────────────
MAIL_FROM=info@dxpstudio.webriq.com
MAIL_HOST=smtp.zeptomail.com
MAIL_PORT=587
MAIL_USER=emailapikey
MAIL_PASS=your-zeptomail-api-key

# ─── Vercel AI Gateway (optional proxy) ──────────────────────────────────────
# Routes AI requests through Vercel's gateway for caching and unified billing.
# Supabase llm_invocation_logs remains the source of truth for per-customer cost attribution.
# Found in: vercel.com/{team}/~/ai-gateway
VERCEL_AI_GATEWAY_URL=
VERCEL_AI_GATEWAY_TOKEN=
