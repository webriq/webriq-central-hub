# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Service role key — server-only, never expose to the client
SUPABASE_SECRET_KEY=your-secret-key

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Anthropic — default provider for all layers
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — optional, switch any layer to OpenAI via llm_config.provider='openai'
# Found in: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Zoho ─────────────────────────────────────────────────────────────────────
# OAuth 2.0 credentials for Zoho Projects, Desk, and Cliq (Sprint 2+)
# These same credentials are entered in Supabase Dashboard (Auth → Providers → Custom → zoho)
# to enable "Sign in with Zoho". Supabase callback URI: https://[project-ref].supabase.co/auth/v1/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Zoho Projects portal ID (numeric) — used in API calls
# Found in: Zoho Projects → Settings → Portal Details
ZOHO_PORTAL_ID=
# Zoho Projects portal name (slug) — used for web URL construction (NEXT_PUBLIC = safe for client)
# Find it in your Zoho Projects URL: https://projects.zoho.com/portal/{name}/
NEXT_PUBLIC_ZOHO_PORTAL_NAME=
# Base URL for your Zoho org (e.g. https://projectsapi.zoho.com)
ZOHO_API_BASE_URL=

# ─── Sanity (Sprint 5+) ───────────────────────────────────────────────────────
# Sanity API token (editor access) — project ID is stored per customer_products row
SANITY_API_TOKEN=

# ─── GitHub (Sprint 5+) ───────────────────────────────────────────────────────
# Fine-grained PAT with repo read/write for PR creation
GITHUB_TOKEN=

# ─── Webhook security (Sprint 2+) ────────────────────────────────────────────
# HMAC key from Zoho Projects → Settings → Automation → Webhooks → Security Settings.
# Zoho signs the raw POST body with HMAC-SHA256 and sends it in X-ZP-WEBHOOK-SIGNATURE (base64).
ZOHO_WEBHOOK_SECRET=

# ─── Digest cron security (Sprint 3+) ─────────────────────────────────────────
# Shared secret between pg_cron (Supabase) and /api/digest route.
# Set the same value in Supabase cron job headers and here.
DIGEST_SECRET=

# ─── Reply route security (Sprint 5+) ────────────────────────────────────────
REPLY_SECRET=                    # Shared secret for POST /api/reply (internal route); generate with: openssl rand -hex 32

# ─── Zoho Cliq channels (Sprint 3+) ──────────────────────────────────────────
# PM digest and general notifications (set in Sprint 2)
# ZOHO_CLIQ_WEBHOOK_URL and ZOHO_CLIQ_WEBHOOK_TOKEN defined above under Zoho section
# Separate channel for dev digest notifications
ZOHO_CLIQ_DEV_WEBHOOK_URL=

# ─── Vercel AI Gateway (optional proxy) ──────────────────────────────────────
# Routes AI requests through Vercel's gateway for caching and unified billing.
# Supabase llm_invocation_logs remains the source of truth for per-customer cost attribution.
# Found in: vercel.com/{team}/~/ai-gateway
VERCEL_AI_GATEWAY_URL=
VERCEL_AI_GATEWAY_TOKEN=
